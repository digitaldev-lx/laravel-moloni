{
    "name": "digitaldev-lx/laravel-moloni",
    "description": "A Laravel package for integrating with the Moloni invoicing API",
    "keywords": ["laravel", "moloni", "invoicing", "portugal", "faturacao"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "larastan/larastan": "^3.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "DigitaldevLx\\LaravelMoloni\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DigitaldevLx\\LaravelMoloni\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage --min=80",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "format:test": "vendor/bin/pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "DigitaldevLx\\LaravelMoloni\\Providers\\MoloniServiceProvider"
            ],
            "aliases": {
                "Moloni": "DigitaldevLx\\LaravelMoloni\\Facades\\Moloni"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
